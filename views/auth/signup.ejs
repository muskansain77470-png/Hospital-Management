<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CareSync | Create Account</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-6">

    <div class="w-full max-w-md bg-white rounded-[2.5rem] shadow-2xl p-10 border border-slate-100">
        <div class="text-center mb-8">
            <p class="text-[10px] font-black text-blue-600 uppercase tracking-[0.3em] mb-2">— JOIN US</p>
            <h1 class="text-3xl font-black text-slate-900 uppercase italic"><%= role %> Registration</h1>
        </div>

        <form id="signupForm" class="space-y-5">
            <input type="hidden" name="role" id="role" value="<%= role %>">

            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-4">Full Name</label>
                <input type="text" name="name" id="name" required class="w-full bg-slate-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-blue-500 font-semibold text-slate-700">
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-4">Email Address</label>
                <input type="email" name="email" id="email" required class="w-full bg-slate-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-blue-500 font-semibold text-slate-700">
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-4">Password</label>
                <input type="password" name="password" id="password" required class="w-full bg-slate-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-blue-500 font-semibold text-slate-700">
            </div>

            <% if(role === 'patient') { %>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-4">Age</label>
                    <input type="number" name="age" id="age" class="w-full bg-slate-50 border-none rounded-2xl py-4 px-6 font-semibold text-slate-700">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-4">Gender</label>
                    <select name="gender" id="gender" class="w-full bg-slate-50 border-none rounded-2xl py-4 px-6 font-semibold text-slate-700">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>
            <% } %>

            <button type="submit" id="submitBtn" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 mt-4">
                Create Account
            </button>
        </form>

        <p class="text-center mt-8 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
            Already have an account? <a href="/login?role=<%= role %>" class="text-blue-600 hover:underline">Login</a>
        </p>
    </div>

    <script>
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const btn = document.getElementById('submitBtn');
            const role = document.getElementById('role').value;
            
            // Loading state
            btn.innerText = "Processing...";
            btn.disabled = true;

            // Form Data collect karna
            const formData = {
                role: role,
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                password: document.getElementById('password').value
            };

            // Agar patient role hai toh age aur gender bhi add karein
            if (role === 'patient') {
                formData.age = document.getElementById('age').value;
                formData.gender = document.getElementById('gender').value;
            }

            try {
                const response = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (response.ok) {
                    alert('✅ Registration Successful!');
                    // Success ke baad dashboard ya login par redirect
                    window.location.href = '/dashboard';
                } else {
                    alert('❌ Error: ' + result.message);
                    btn.innerText = "Create Account";
                    btn.disabled = false;
                }
            } catch (error) {
                console.error('Fetch Error:', error);
                alert('Something went wrong. Please try again.');
                btn.innerText = "Create Account";
                btn.disabled = false;
            }
        });
    </script>

</body>
</html>