<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= role %> Registration | CareSync HMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-2xl shadow-blue-100/50 border border-slate-100">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 <%= role === 'staff' ? 'bg-blue-600' : 'bg-emerald-600' %> rounded-2xl mb-6 shadow-lg shadow-blue-200">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                </svg>
            </div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight uppercase">CREATE <%= role %> ACCOUNT</h1>
            <p class="text-slate-400 text-sm font-semibold mt-2 uppercase tracking-widest leading-relaxed">
                <%= role === 'staff' ? 'Join the Medical Staff Team' : 'Register for Patient Services' %>
            </p>
        </div>

        <div id="message" class="hidden mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border transition-all"></div>

        <form id="signupForm" class="space-y-5">
            <input type="hidden" id="userRole" value="<%= role %>">

            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Full Name</label>
                <input type="text" id="name" 
                    class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-blue-500/5 focus:border-blue-500 focus:outline-none transition-all placeholder:text-slate-300 font-medium" 
                    placeholder="<%= role === 'staff' ? 'e.g. Dr. Alexander' : 'e.g. John Doe' %>" required />
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    <%= role === 'staff' ? 'Official Email' : 'Personal Email' %>
                </label>
                <input type="email" id="email" 
                    class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-blue-500/5 focus:border-blue-500 focus:outline-none transition-all placeholder:text-slate-300 font-medium" 
                    placeholder="<%= role === 'staff' ? 'doctor@hospital.com' : 'yourname@email.com' %>" required />
            </div>
            
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Password</label>
                <input type="password" id="password" 
                    class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-blue-500/5 focus:border-blue-500 focus:outline-none transition-all placeholder:text-slate-300 font-medium" 
                    placeholder="••••••••" required />
            </div>

            <button type="submit" id="submitBtn" 
                class="w-full <%= role === 'staff' ? 'bg-blue-950 hover:bg-blue-800 shadow-blue-900/20' : 'bg-emerald-900 hover:bg-emerald-800 shadow-emerald-900/20' %> text-white py-5 rounded-2xl font-black text-sm uppercase tracking-widest shadow-xl transition duration-300 transform active:scale-95">
                Register as <%= role %>
            </button>
        </form>

        <p class="mt-10 text-center text-[11px] font-bold text-slate-400 uppercase tracking-widest">
            Already registered? <a href="/login?role=<%= role %>" class="text-blue-600 hover:underline">Login here</a>
        </p>
    </div>

    <script>
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const role = document.getElementById('userRole').value;
            const messageEl = document.getElementById('message');
            const btn = document.getElementById('submitBtn');

            messageEl.classList.add('hidden');
            btn.disabled = true;
            btn.innerText = "CREATING ACCOUNT...";

            try {
                const response = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password, role })
                });

                const data = await response.json();

                if (response.ok) {
                    messageEl.className = "mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border bg-green-50 text-green-600 border-green-100 block";
                    messageEl.innerText = 'Account created! Redirecting to login...';
                    
                    setTimeout(() => {
                        window.location.href = `/login?role=${role}`;
                    }, 1500);
                } else {
                    throw new Error(data.message || 'Registration failed');
                }
            } catch (err) {
                messageEl.className = "mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border bg-red-50 text-red-600 border-red-100 block";
                messageEl.innerText = err.message;
            } finally {
                btn.disabled = false;
                btn.innerText = `REGISTER AS ${role.toUpperCase()}`;
            }
        });
    </script>
</body>
</html>