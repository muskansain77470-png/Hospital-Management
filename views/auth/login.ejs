<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | CareSync HMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6">

    <div id="roleSelection" class="bg-white w-full max-w-2xl p-10 rounded-[2.5rem] shadow-2xl border border-slate-100 text-center">
        <h1 class="text-3xl font-black text-slate-800 mb-2">WELCOME TO CARESYNC</h1>
        <p class="text-slate-400 font-bold text-xs uppercase tracking-widest mb-10">Please select your portal to login</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <button onclick="selectRole('doctor')" class="group p-6 rounded-3xl border-2 border-slate-100 hover:border-blue-500 transition-all bg-white hover:shadow-xl">
                <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-600 transition-colors">
                    <span class="text-2xl group-hover:scale-110 transition-transform">👨‍⚕️</span>
                </div>
                <h3 class="font-black text-slate-700 uppercase text-sm tracking-widest">Doctor</h3>
            </button>

            <button onclick="selectRole('staff')" class="group p-6 rounded-3xl border-2 border-slate-100 hover:border-blue-500 transition-all bg-white hover:shadow-xl">
                <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-indigo-600 transition-colors">
                    <span class="text-2xl group-hover:scale-110 transition-transform">📋</span>
                </div>
                <h3 class="font-black text-slate-700 uppercase text-sm tracking-widest">Staff</h3>
            </button>

            <button onclick="selectRole('patient')" class="group p-6 rounded-3xl border-2 border-slate-100 hover:border-emerald-500 transition-all bg-white hover:shadow-xl">
                <div class="w-16 h-16 bg-emerald-100 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-emerald-600 transition-colors">
                    <span class="text-2xl group-hover:scale-110 transition-transform">👤</span>
                </div>
                <h3 class="font-black text-slate-700 uppercase text-sm tracking-widest">Patient</h3>
            </button>
        </div>
    </div>

    <div id="loginContainer" class="hidden bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-2xl border border-slate-100">
        <button onclick="location.reload()" class="text-[10px] font-black text-slate-400 hover:text-blue-600 uppercase mb-6 flex items-center gap-2">
            ← Change Role
        </button>
        <div class="text-center mb-10">
            <h1 id="formTitle" class="text-3xl font-black text-slate-800 tracking-tight uppercase">LOGIN</h1>
            <p id="formSubtitle" class="text-slate-400 text-sm font-semibold mt-2 uppercase tracking-widest">Portal Access</p>
        </div>

        <div id="message" class="hidden mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border"></div>

        <form id="loginForm" class="space-y-6">
            <input type="hidden" id="userRole">
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                <input type="email" id="email" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-blue-500 focus:outline-none transition-all font-medium" required>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Password</label>
                <input type="password" id="password" class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:border-blue-500 focus:outline-none transition-all font-medium" required>
            </div>
            <button type="submit" id="submitBtn" class="w-full bg-blue-950 text-white py-5 rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-blue-800 transition transform active:scale-95">
                Login
            </button>
        </form>
    </div>

    <script>
        function selectRole(role) {
            document.getElementById('roleSelection').classList.add('hidden');
            document.getElementById('loginContainer').classList.remove('hidden');
            document.getElementById('userRole').value = role;
            document.getElementById('formTitle').innerText = role + " Login";
            document.getElementById('submitBtn').innerText = "Login as " + role.toUpperCase();
        }

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const role = document.getElementById('userRole').value;
            const btn = document.getElementById('submitBtn');
            const messageEl = document.getElementById('message');

            btn.disabled = true;
            btn.innerText = "VERIFYING...";

            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, role })
                });
                const data = await response.json();
                if (response.ok) {
                    messageEl.className = "mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border bg-green-50 text-green-600 border-green-100 block";
                    messageEl.innerText = 'Login successful! Redirecting...';
                    setTimeout(() => { window.location.href = `/dashboard?token=${data.token}`; }, 1200);
                } else {
                    throw new Error(data.message || 'Invalid credentials');
                }
            } catch (err) {
                messageEl.className = "mb-6 p-4 rounded-2xl text-center text-[13px] font-bold border bg-red-50 text-red-600 border-red-100 block";
                messageEl.innerText = err.message;
                btn.disabled = false;
                btn.innerText = `LOGIN AS ${role.toUpperCase()}`;
            }
        });
    </script>
</body>
</html>