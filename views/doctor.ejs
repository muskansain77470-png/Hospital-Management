<div class="min-h-screen bg-slate-50/50 p-4 lg:p-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
        <div>
            <h1 class="text-4xl font-black text-slate-800 tracking-tight mb-2">
                Welcome back, <span class="text-blue-600">Dr. <%= user.name %></span>
            </h1>
            <div class="flex items-center gap-2">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                </span>
                <p class="text-slate-500 font-bold text-sm">System is synced with CareSync Database.</p>
            </div>
        </div>
        <a href="/doctor/appointments" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-2xl font-black text-sm shadow-xl shadow-blue-200 transition-all transform hover:-translate-y-1 text-center">
            View Full Schedule
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm group">
            <div class="p-3 bg-blue-50 rounded-2xl w-fit mb-6 group-hover:bg-blue-100 transition-colors">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
            </div>
            <h3 class="text-4xl font-black text-slate-800 mb-1"><%= stats.activePatients %></h3>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total Patients</p>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
            <div class="p-3 bg-orange-50 rounded-2xl w-fit mb-6">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <h3 class="text-4xl font-black text-slate-800 mb-1"><%= stats.pending %></h3>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">New Requests</p>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
            <div class="p-3 bg-green-50 rounded-2xl w-fit mb-6">
                <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944"></path>
                </svg>
            </div>
            <h3 class="text-3xl font-black text-slate-800 mb-1 italic text-emerald-500">Secure</h3>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">End-to-End Encryption</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white rounded-[2.5rem] border border-slate-100 p-8 shadow-sm">
                <h3 class="font-black text-slate-800 text-lg mb-6 flex items-center gap-2">
                    Action Required <span class="bg-orange-100 text-orange-600 text-[10px] px-2 py-0.5 rounded-md uppercase tracking-tighter italic">Schedule Now</span>
                </h3>
                <div class="space-y-4">
                    <% let pendingItems = recentAppointments.filter(a => a.status === 'Pending'); %>
                    <% if (pendingItems.length > 0) { %>
                        <% pendingItems.forEach(item => { %>
                            <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 hover:border-blue-200 transition-all">
                                <form action="/doctor/confirm-appointment" method="POST" class="flex flex-col xl:flex-row gap-4 items-center justify-between">
                                    <input type="hidden" name="appointmentId" value="<%= item._id %>">
                                    <div class="flex items-center gap-4 w-full">
                                        <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-black text-lg shrink-0">
                                            <%= item.patient.name.charAt(0) %>
                                        </div>
                                        <div class="overflow-hidden">
                                            <p class="font-black text-slate-800 text-sm truncate"><%= item.patient.name %></p>
                                            <p class="text-slate-500 text-[10px] font-bold italic">"<%= item.reason %>"</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex gap-2 w-full xl:w-auto">
                                        <input type="date" name="date" required class="flex-1 xl:w-32 px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:ring-2 focus:ring-blue-100 outline-none">
                                        <input type="time" name="time" required class="flex-1 xl:w-28 px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:ring-2 focus:ring-blue-100 outline-none">
                                        <button type="submit" class="bg-slate-900 text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 transition-all">
                                            Confirm
                                        </button>
                                    </div>
                                </form>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-8 bg-slate-50 rounded-[2rem] border border-dashed border-slate-200">
                            <p class="text-slate-400 text-xs font-black uppercase tracking-widest">Inbox Zero: No pending requests</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="bg-white rounded-[2.5rem] border border-slate-100 p-8 shadow-sm">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="font-black text-slate-800 text-lg">Confirmed Consultations</h3>
                    <a href="/doctor/appointments" class="text-blue-600 font-bold text-xs uppercase tracking-widest hover:underline">Full Schedule</a>
                </div>
                <div class="space-y-4">
                    <% let confirmedItems = recentAppointments.filter(a => a.status !== 'Pending'); %>
                    <% if (confirmedItems.length > 0) { %>
                        <% confirmedItems.forEach(item => { %>
                            <div class="flex flex-wrap md:flex-nowrap items-center justify-between p-5 bg-slate-50 rounded-3xl border border-slate-100 hover:bg-white hover:shadow-md transition-all group">
                                <div class="flex items-center gap-4 mb-4 md:mb-0">
                                    <div class="w-12 h-12 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 font-black text-lg">
                                        <%= item.patient.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <p class="font-black text-slate-800 text-base"><%= item.patient.name %></p>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[9px] font-black px-2 py-0.5 rounded bg-blue-100 text-blue-600 uppercase tracking-tighter"><%= item.status %></span>
                                            <% if(item.date) { %>
                                                <span class="text-[10px] font-bold text-slate-400"><%= new Date(item.date).toLocaleDateString() %> • <%= item.time %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="flex items-center gap-3 w-full md:w-auto">
                                    <button onclick="window.open('https://meet.jit.si/CareSync-<%= item._id %>', '_blank')" class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-blue-700 shadow-lg shadow-blue-100 transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                        Join
                                    </button>
                                    <a href="/doctor/prescription/<%= item._id %>" class="p-3 bg-white text-slate-400 rounded-2xl border border-slate-100 hover:border-emerald-500 hover:text-emerald-600 transition-all group-hover:scale-105" title="Prescribe">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-slate-400 text-sm font-bold uppercase text-center py-6">No active consultations at the moment</p>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="space-y-8">
            <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white relative overflow-hidden shadow-2xl shadow-blue-100">
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-8">
                        <div class="p-3 bg-white/10 rounded-2xl">
                            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                            </svg>
                        </div>
                        <span class="bg-red-500 text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-tighter shadow-lg shadow-red-500/50">Urgent Tasks</span>
                    </div>
                    <h4 class="text-2xl font-black mb-4 leading-tight italic">Pending Schedules</h4>
                    <p class="text-slate-400 text-sm font-semibold mb-8">Patients are waiting for your confirmation. Early scheduling increases patient satisfaction ratings by 40%.</p>
                    <button class="w-full py-4 bg-white text-slate-900 rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-blue-400 transition-colors shadow-xl">
                        Review All Tasks
                    </button>
                </div>
                <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-blue-600/10 rounded-full blur-3xl"></div>
            </div>
            
            <div class="bg-blue-600 rounded-[2.5rem] p-8 text-white shadow-xl">
                <p class="text-[10px] font-black uppercase tracking-widest opacity-60 mb-2">Doctor Tip</p>
                <p class="text-sm font-bold italic">"Always finalize prescriptions right after the call to ensure data accuracy in the Billing Center."</p>
            </div>
        </div>
    </div>
</div>