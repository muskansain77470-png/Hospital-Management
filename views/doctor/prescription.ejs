<div class="min-h-screen bg-slate-50/50 p-4 lg:p-12">
    <div class="max-w-4xl mx-auto">
        
        <div class="bg-white rounded-[2.5rem] p-8 border border-slate-200 shadow-sm mb-8">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h1 class="text-3xl font-black text-slate-900 tracking-tight">Write <span class="text-blue-600">Prescription</span></h1>
                    <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest mt-1">Medical Record #<%= appointment._id.toString().slice(-6).toUpperCase() %></p>
                </div>
                <a href="/appointments" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 py-6 border-y border-slate-50">
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Patient</p>
                    <p class="font-bold text-slate-800"><%= appointment.patient.name %></p>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Gender/Age</p>
                    <p class="font-bold text-slate-800"><%= appointment.patient.gender %> / <%= appointment.patient.age || 'N/A' %></p>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Reason</p>
                    <p class="font-bold text-blue-600"><%= appointment.reason %></p>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Date</p>
                    <p class="font-bold text-slate-800"><%= new Date().toLocaleDateString() %></p>
                </div>
            </div>
        </div>

        <form action="/api/doctor/prescription" method="POST" class="space-y-6">
            <input type="hidden" name="appointmentId" value="<%= appointment._id %>">
            <input type="hidden" name="patientId" value="<%= appointment.patient._id %>">

            <div class="bg-white rounded-[2.5rem] p-8 border border-slate-200 shadow-sm">
                <div class="mb-8">
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-3 ml-2">Diagnosis / Clinical Notes</label>
                    <textarea name="diagnosis" rows="2" class="w-full bg-slate-50 border-none rounded-2xl p-4 font-medium text-slate-700 focus:ring-2 focus:ring-blue-500" placeholder="Enter patient's condition..." required></textarea>
                </div>

                <div class="space-y-4">
                    <div class="flex justify-between items-center mb-4">
                        <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Medicines & Dosage</label>
                        <button type="button" onclick="addMedicineRow()" class="text-blue-600 font-black text-[10px] uppercase tracking-widest hover:text-blue-700">+ Add Medicine</button>
                    </div>

                    <div id="medicineList" class="space-y-3">
                        <div class="grid grid-cols-12 gap-3 medicine-row">
                            <div class="col-span-5">
                                <input type="text" name="medicines[0][name]" placeholder="Medicine Name" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
                            </div>
                            <div class="col-span-3">
                                <input type="text" name="medicines[0][dosage]" placeholder="Dosage (500mg)" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
                            </div>
                            <div class="col-span-3">
                                <input type="text" name="medicines[0][duration]" placeholder="Duration (5 Days)" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
                            </div>
                            <div class="col-span-1 flex items-center justify-center">
                                </div>
                        </div>
                    </div>
                </div>

                <div class="mt-8">
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-3 ml-2">Additional Instructions</label>
                    <textarea name="instructions" rows="2" class="w-full bg-slate-50 border-none rounded-2xl p-4 font-medium text-slate-700 focus:ring-2 focus:ring-blue-500" placeholder="e.g. Take after meals, Drink plenty of water..."></textarea>
                </div>
            </div>

            <div class="flex gap-4">
                <button type="submit" class="flex-1 bg-blue-600 text-white py-5 rounded-[2rem] font-black shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all uppercase tracking-widest text-xs">
                    Save Prescription & Close Case
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    let medicineCount = 1;

    function addMedicineRow() {
        const list = document.getElementById('medicineList');
        const row = document.createElement('div');
        row.className = 'grid grid-cols-12 gap-3 medicine-row animate-in slide-in-from-top-2 duration-300';
        row.innerHTML = `
            <div class="col-span-5">
                <input type="text" name="medicines[\${medicineCount}][name]" placeholder="Medicine Name" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
            </div>
            <div class="col-span-3">
                <input type="text" name="medicines[\${medicineCount}][dosage]" placeholder="Dosage" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
            </div>
            <div class="col-span-3">
                <input type="text" name="medicines[\${medicineCount}][duration]" placeholder="Duration" class="w-full bg-slate-50 border-none rounded-xl p-3 text-sm font-bold" required>
            </div>
            <div class="col-span-1 flex items-center justify-center">
                <button type="button" onclick="this.parentElement.parentElement.remove()" class="text-red-400 hover:text-red-600 font-bold">×</button>
            </div>
        `;
        list.appendChild(row);
        medicineCount++;
    }
</script>