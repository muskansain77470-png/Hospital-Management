<div class="min-h-screen bg-slate-50/50 p-4 lg:p-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Schedules</h1>
            <p class="text-slate-500 font-semibold text-sm">Manage and monitor hospital appointments.</p>
        </div>
        <% if (user.role === 'staff' || user.role === 'doctor') { %>
        <button onclick="openModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold text-sm shadow-lg shadow-blue-200 transition-all flex items-center gap-2 w-fit">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path>
            </svg>
            New Appointment
        </button>
        <% } %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Assigned</p>
            <h3 class="text-2xl font-black text-slate-800"><%= appointments.length %></h3>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-blue-500 uppercase tracking-widest mb-1">Pending Action</p>
            <h3 class="text-2xl font-black text-slate-800"><%= appointments.filter(a => a.status === 'Pending').length %></h3>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm text-center">
            <p class="text-[10px] font-bold text-green-500 uppercase tracking-widest mb-1">Completed Today</p>
            <h3 class="text-2xl font-black text-slate-800"><%= appointments.filter(a => a.status === 'Completed').length %></h3>
        </div>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-blue-100/20 overflow-hidden">
        <div class="p-6 border-b border-slate-50 flex flex-col md:flex-row gap-4 justify-between items-center">
            <h3 class="font-black text-slate-800 uppercase text-xs tracking-widest">Appointment Registry</h3>
            <div class="relative w-full md:w-72">
                <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Search by patient..." class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 transition-all">
                <svg class="w-4 h-4 text-slate-400 absolute left-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                        <th class="px-6 py-4">Patient Info</th>
                        <th class="px-6 py-4">Schedule</th>
                        <th class="px-6 py-4">Current Status</th>
                        <th class="px-6 py-4 text-right">Quick Actions</th>
                    </tr>
                </thead>
                <tbody id="appointmentList" class="divide-y divide-slate-50">
                    <% appointments.forEach(app => { %>
                    <tr class="hover:bg-blue-50/30 transition-colors">
                        <td class="px-6 py-4">
                            <p class="font-bold text-slate-800 text-sm"><%= app.patient ? app.patient.name : 'Unknown' %></p>
                            <p class="text-[10px] text-slate-400 font-bold uppercase"><%= app.patient ? app.patient.phone : 'No Contact' %></p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-slate-800 font-bold text-xs"><%= new Date(app.date).toDateString() %></p>
                            <p class="text-blue-500 font-bold text-[10px] uppercase"><%= app.time %></p>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest 
                                <%= app.status === 'Completed' ? 'bg-green-100 text-green-600' : 
                                    app.status === 'Cancelled' ? 'bg-red-100 text-red-600' : 
                                    app.status === 'Confirmed' ? 'bg-blue-100 text-blue-600' : 'bg-amber-100 text-amber-600' %>">
                                <%= app.status %>
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <% if (app.status === 'Pending') { %>
                                    <button onclick="updateStatus('<%= app._id %>', 'Confirmed')" class="bg-blue-50 text-blue-600 p-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all">
                                        Confirm
                                    </button>
                                    <button onclick="updateStatus('<%= app._id %>', 'Cancelled')" class="bg-red-50 text-red-600 p-2 rounded-lg hover:bg-red-600 hover:text-white transition-all">
                                        Reject
                                    </button>
                                <% } else if (app.status === 'Confirmed' && user.role === 'doctor') { %>
                                    <button onclick="window.location.href='/doctor/prescription/<%= app._id %>'" class="bg-green-600 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-green-100">
                                        Add Prescription
                                    </button>
                                <% } else { %>
                                    <span class="text-slate-300 text-[10px] font-black uppercase">No Actions</span>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    async function updateStatus(id, newStatus) {
        if(!confirm(`Confirm ${newStatus}?`)) return;
        
        try {
            const response = await fetch(`/api/doctor/appointments/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });

            if (response.ok) {
                location.reload(); // Reload to reflect changes
            } else {
                alert("Failed to update status");
            }
        } catch (error) {
            alert("Network Error");
        }
    }

    function searchTable() {
        const input = document.getElementById("searchInput").value.toUpperCase();
        const rows = document.getElementById("appointmentList").getElementsByTagName("tr");
        for (let row of rows) {
            const nameCol = row.getElementsByTagName("td")[0];
            if (nameCol) {
                const text = nameCol.textContent || nameCol.innerText;
                row.style.display = text.toUpperCase().includes(input) ? "" : "none";
            }
        }
    }
</script>