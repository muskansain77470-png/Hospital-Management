<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pharmacy | CareSync</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
    </style>
</head>
<body>

    <%- include('../partials/header') %>

    <main class="max-w-7xl mx-auto px-6 py-12">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Pharmacy <span class="text-blue-600">Inventory</span></h1>
                <p class="text-slate-500 font-medium mt-2">Manage medical stock and dispensed prescriptions.</p>
            </div>
            <div class="flex gap-4">
                <button class="bg-white border border-slate-200 text-slate-700 px-6 py-3 rounded-2xl font-bold hover:bg-slate-50 transition-all shadow-sm">Export Report</button>
                <button class="bg-blue-600 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all">+ Add Medicine</button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div class="glass-card p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50">
                <div class="w-12 h-12 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                </div>
                <h3 class="text-slate-400 text-xs font-black uppercase tracking-widest mb-1">Total Medicines</h3>
                <p class="text-4xl font-black text-slate-900">1,284</p>
            </div>

            <div class="glass-card p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50">
                <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.268 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <h3 class="text-slate-400 text-xs font-black uppercase tracking-widest mb-1">Low Stock Alert</h3>
                <p class="text-4xl font-black text-slate-900 text-amber-600">12</p>
            </div>

            <div class="glass-card p-8 rounded-[2.5rem] shadow-xl shadow-slate-200/50">
                <div class="w-12 h-12 bg-emerald-100 rounded-2xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <h3 class="text-slate-400 text-xs font-black uppercase tracking-widest mb-1">Dispensed Today</h3>
                <p class="text-4xl font-black text-slate-900">48</p>
            </div>
        </div>

        <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200/60 overflow-hidden border border-slate-100">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Medicine Name</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Category</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Stock Level</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr class="hover:bg-slate-50/50 transition-all cursor-pointer">
                        <td class="px-10 py-6 font-bold text-slate-800">Paracetamol 500mg</td>
                        <td class="px-10 py-6 font-medium text-slate-500 text-sm font-semibold italic">Analgesic</td>
                        <td class="px-10 py-6 font-bold text-slate-700">450 Units</td>
                        <td class="px-10 py-6">
                            <span class="px-4 py-1.5 rounded-full text-[10px] font-black bg-emerald-100 text-emerald-700 uppercase tracking-widest">In Stock</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-50/50 transition-all cursor-pointer">
                        <td class="px-10 py-6 font-bold text-slate-800">Amoxicillin</td>
                        <td class="px-10 py-6 font-medium text-slate-500 text-sm font-semibold italic">Antibiotic</td>
                        <td class="px-10 py-6 font-bold text-slate-700 text-amber-600">12 Units</td>
                        <td class="px-10 py-6">
                            <span class="px-4 py-1.5 rounded-full text-[10px] font-black bg-amber-100 text-amber-700 uppercase tracking-widest">Low Stock</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>