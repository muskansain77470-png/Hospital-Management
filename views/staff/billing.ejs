<div class="min-h-screen bg-slate-50 p-6 lg:p-12">
    <div class="max-w-6xl mx-auto space-y-10">
        
        <div class="flex flex-col md:flex-row justify-between items-center bg-white p-8 rounded-[2.5rem] border border-slate-200/60 shadow-sm gap-4">
            <div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight">Billing <span class="text-blue-600">Center</span></h1>
                <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest mt-1">Hospital Revenue & Invoicing</p>
            </div>
            <div class="flex gap-4">
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-400 uppercase">Current Session</p>
                    <p class="font-bold text-slate-700"><%= new Date().toLocaleDateString() %></p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm">
                    <h3 class="text-xl font-black text-slate-800 mb-6">Generate Invoice</h3>
                    
                    <form action="/staff/billing/create" method="POST" id="billingForm" class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase mb-2">Select Appointment</label>
                            <select name="appointmentId" id="appointmentSelect" class="w-full bg-slate-50 border-none rounded-xl p-4 font-bold text-slate-700 focus:ring-2 focus:ring-blue-500" required>
                                <option value="">-- Choose Patient --</option>
                                <% appointments.forEach(appt => { %>
                                    <% if(appt.paymentStatus !== 'Paid') { %>
                                        <option value="<%= appt._id %>" data-patient-id="<%= appt.patient._id %>">
                                            <%= appt.patient.name %> (<%= appt.reason %>)
                                        </option>
                                    <% } %>
                                <% }) %>
                            </select>
                        </div>

                        <input type="hidden" name="patientId" id="patientIdInput">

                        <div id="billItems" class="space-y-3">
                            <label class="block text-[10px] font-black text-slate-400 uppercase">Services & Costs</label>
                            <div class="flex gap-2 item-row">
                                <input type="text" name="services[]" placeholder="Service (e.g. Consultation)" class="flex-1 bg-slate-50 border-none rounded-xl p-3 text-sm font-medium" required>
                                <input type="number" name="costs[]" placeholder="Cost" class="w-24 bg-slate-50 border-none rounded-xl p-3 text-sm font-medium" required>
                            </div>
                        </div>

                        <button type="button" onclick="addItemRow()" class="w-full py-2 border-2 border-dashed border-slate-200 rounded-xl text-slate-400 text-xs font-black hover:bg-slate-50 transition-all">
                            + ADD ANOTHER SERVICE
                        </button>

                        <hr class="border-slate-100 my-6">

                        <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-black shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all uppercase tracking-widest text-xs">
                            Generate & Finalize Bill
                        </button>
                    </form>
                </div>
            </div>

            <div class="lg:col-span-2">
                <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-8 py-6 border-b border-slate-50 flex justify-between items-center">
                        <h3 class="text-xl font-black text-slate-800">Recent Invoices</h3>
                        <span class="bg-green-100 text-green-600 text-[10px] font-black px-3 py-1 rounded-full uppercase">Live Sync</span>
                    </div>
                    
                    <div class="p-4 overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                    <th class="px-4 py-4">Invoice #</th>
                                    <th class="px-4 py-4">Patient</th>
                                    <th class="px-4 py-4">Total Amount</th>
                                    <th class="px-4 py-4 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                                <% if (recentBills && recentBills.length > 0) { %>
                                    <% recentBills.forEach(bill => { %>
                                        <tr class="group hover:bg-slate-50 transition-colors">
                                            <td class="px-4 py-5 font-mono font-bold text-blue-600"><%= bill.invoiceNumber %></td>
                                            <td class="px-4 py-5 font-black text-slate-700"><%= bill.patient.name %></td>
                                            <td class="px-4 py-5 font-bold text-slate-900">₹<%= bill.totalAmount.toLocaleString() %></td>
                                            <td class="px-4 py-5 text-right">
                                                <button class="text-[10px] font-black bg-slate-100 text-slate-500 px-4 py-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all uppercase">
                                                    Print
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="p-12 text-center text-slate-400 font-bold italic">No bills generated today yet.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Logic to update hidden Patient ID when appointment is selected
    document.getElementById('appointmentSelect').addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const patientId = selectedOption.getAttribute('data-patient-id');
        document.getElementById('patientIdInput').value = patientId;
    });

    // Dynamic Row Adder for Services
    function addItemRow() {
        const container = document.getElementById('billItems');
        const newRow = document.createElement('div');
        newRow.className = 'flex gap-2 item-row animate-in fade-in duration-300';
        newRow.innerHTML = `
            <input type="text" name="services[]" placeholder="Service Name" class="flex-1 bg-slate-50 border-none rounded-xl p-3 text-sm font-medium" required>
            <input type="number" name="costs[]" placeholder="Cost" class="w-24 bg-slate-50 border-none rounded-xl p-3 text-sm font-medium" required>
            <button type="button" onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 px-2">×</button>
        `;
        container.appendChild(newRow);
    }
</script>