<div class="min-h-screen bg-slate-50 p-6 lg:p-12">
    <div class="max-w-6xl mx-auto space-y-10">
        
        <div class="flex flex-col md:flex-row justify-between items-center bg-white p-8 rounded-[2.5rem] border border-slate-200/60 shadow-sm gap-4">
            <div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight">Billing <span class="text-blue-600">Center</span></h1>
                <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest mt-1">Hospital Revenue & Invoicing</p>
            </div>
            <div class="flex gap-4 text-right">
                <div class="bg-blue-50 px-6 py-2 rounded-2xl border border-blue-100">
                    <p class="text-[10px] font-black text-blue-400 uppercase">Current Session</p>
                    <p class="font-bold text-blue-700"><%= new Date().toLocaleDateString('en-IN') %></p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm sticky top-8">
                    <h3 class="text-xl font-black text-slate-800 mb-6">Generate Invoice</h3>
                    
                    <form action="/staff/billing/create" method="POST" id="billingForm" class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 ml-1">Select Appointment</label>
                            <select name="appointmentId" id="appointmentSelect" class="w-full bg-slate-50 border-none rounded-xl p-4 font-bold text-slate-700 focus:ring-2 focus:ring-blue-500 transition-all cursor-pointer" required>
                                <option value="">-- Choose Patient --</option>
                                <% if (appointments && appointments.length > 0) { %>
                                    <% appointments.forEach(appt => { %>
                                        <% if(appt.status === 'Completed' && appt.paymentStatus !== 'Paid' && appt.patient) { %>
                                            <option value="<%= appt._id %>" data-patient-id="<%= appt.patient._id %>">
                                                <%= appt.patient.name %> (<%= appt.reason || 'Checkup' %>)
                                            </option>
                                        <% } %>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>

                        <input type="hidden" name="patientId" id="patientIdInput">

                        <div id="billItems" class="space-y-3">
                            <label class="block text-[10px] font-black text-slate-400 uppercase ml-1">Services & Costs</label>
                            <div class="flex gap-2 item-row group">
                                <input type="text" name="services[]" placeholder="e.g. Consultation" class="flex-1 bg-slate-50 border-none rounded-xl p-3 text-sm font-bold focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all" required>
                                <input type="number" name="costs[]" placeholder="₹" class="w-24 bg-slate-50 border-none rounded-xl p-3 text-sm font-bold focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all" required>
                            </div>
                        </div>

                        <button type="button" onclick="addItemRow()" class="w-full py-3 border-2 border-dashed border-slate-100 rounded-xl text-slate-400 text-[10px] font-black hover:border-blue-200 hover:text-blue-500 hover:bg-blue-50/30 transition-all uppercase tracking-widest">
                            + Add Another Service
                        </button>

                        <div class="pt-4 mt-6 border-t border-slate-50">
                            <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-black shadow-xl shadow-slate-200 hover:bg-blue-600 transform hover:-translate-y-1 transition-all uppercase tracking-widest text-[11px]">
                                Finalize & Print Bill
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="lg:col-span-2">
                <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-8 py-6 border-b border-slate-50 flex justify-between items-center bg-slate-50/30">
                        <h3 class="text-xl font-black text-slate-800">Recent Invoices</h3>
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                            <span class="text-slate-400 text-[10px] font-black uppercase tracking-widest">Live System</span>
                        </div>
                    </div>
                    
                    <div class="p-0 overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50">
                                    <th class="px-8 py-5">Invoice #</th>
                                    <th class="px-8 py-5">Patient Details</th>
                                    <th class="px-8 py-5">Amount</th>
                                    <th class="px-8 py-5 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                                <% if (recentBills && recentBills.length > 0) { %>
                                    <% recentBills.forEach(bill => { %>
                                        <tr class="group hover:bg-blue-50/30 transition-all">
                                            <td class="px-8 py-6 font-mono font-bold text-blue-600 text-sm">
                                                <%= bill.invoiceNumber || 'INV-' + bill._id.toString().slice(-6).toUpperCase() %>
                                            </td>
                                            <td class="px-8 py-6">
                                                <p class="font-black text-slate-800"><%= bill.patient ? bill.patient.name : 'Unknown' %></p>
                                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter italic">Date: <%= new Date(bill.createdAt).toLocaleDateString() %></p>
                                            </td>
                                            <td class="px-8 py-6 font-black text-slate-900">
                                                ₹<%= bill.totalAmount ? bill.totalAmount.toLocaleString('en-IN') : '0' %>
                                            </td>
                                            <td class="px-8 py-6 text-right">
                                                <button onclick="window.print()" class="text-[10px] font-black bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl group-hover:bg-blue-600 group-hover:text-white group-hover:border-blue-600 transition-all uppercase shadow-sm">
                                                    Print
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="p-20 text-center">
                                            <div class="flex flex-col items-center opacity-30">
                                                <svg class="w-12 h-12 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                <p class="font-black text-slate-400 uppercase tracking-widest text-xs">No invoices generated yet.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Update hidden Patient ID when appointment is selected
    document.getElementById('appointmentSelect').addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const patientId = selectedOption.getAttribute('data-patient-id');
        document.getElementById('patientIdInput').value = patientId || '';
    });

    // Dynamic Row Adder with ID tracking
    function addItemRow() {
        const container = document.getElementById('billItems');
        const newRow = document.createElement('div');
        newRow.className = 'flex gap-2 item-row animate-in slide-in-from-left duration-300';
        newRow.innerHTML = `
            <input type="text" name="services[]" placeholder="Service Name" class="flex-1 bg-slate-50 border-none rounded-xl p-3 text-sm font-bold focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all" required>
            <input type="number" name="costs[]" placeholder="₹" class="w-24 bg-slate-50 border-none rounded-xl p-3 text-sm font-bold focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all" required>
            <button type="button" onclick="this.parentElement.remove()" class="w-10 h-11 flex items-center justify-center bg-red-50 text-red-400 rounded-xl hover:bg-red-500 hover:text-white transition-all font-black">×</button>
        `;
        container.appendChild(newRow);
    }
</script>