<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CareSync HMS | Healthcare Excellence</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        .gradient-text { background: linear-gradient(to right, #2563eb, #059669); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body class="bg-white text-slate-900">

    <%- include('partials/header') %>

    <section class="relative h-[600px] flex items-center px-12 overflow-hidden bg-slate-50">
        <div class="relative z-10 max-w-3xl">
            <h1 class="text-7xl font-extrabold text-slate-900 leading-[1.1] mb-8">
                Healthcare for <span class="gradient-text">Good.</span> <br> Today. Tomorrow.
            </h1>
            <p class="text-slate-500 text-lg font-medium mb-10 max-w-lg leading-relaxed">
                Experience world-class medical facilities and expert consultations at your fingertips.
            </p>
            <div class="relative max-w-xl group">
                <input type="text" placeholder="Search for Doctors or Specialities..." 
                    class="w-full py-6 px-10 rounded-3xl shadow-2xl border-none outline-none text-lg">
                <button class="absolute right-4 top-3 bg-blue-600 p-4 rounded-2xl text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>
        </div>
        <div class="absolute right-0 top-0 w-1/2 h-full opacity-40">
            <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80" alt="Hospital" class="object-cover h-full w-full">
        </div>
    </section>

    <div class="px-12 -mt-24 relative z-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            
            <div class="group bg-white p-10 rounded-[2.5rem] shadow-2xl hover:shadow-blue-100 transition-all border border-slate-50">
                <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 text-3xl">👨‍⚕️</div>
                <h3 class="text-2xl font-bold mb-3">Doctor Portal</h3>
                <p class="text-slate-400 text-sm mb-6">Manage patients and digital prescriptions.</p>
                <div class="flex flex-col gap-3">
                    <a href="/login?role=doctor" class="text-blue-600 font-black text-[10px] uppercase tracking-widest hover:translate-x-2 transition-transform">Login to Portal →</a>
                    <a href="/signup?role=doctor" class="text-slate-400 font-black text-[10px] uppercase tracking-widest hover:text-blue-600">Register as Doctor</a>
                </div>
            </div>

            <div class="group bg-white p-10 rounded-[2.5rem] shadow-2xl hover:shadow-emerald-100 transition-all border border-slate-50">
                <div class="w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-emerald-600 text-3xl">👤</div>
                <h3 class="text-2xl font-bold mb-3">Patient Portal</h3>
                <p class="text-slate-400 text-sm mb-6">Book appointments and access reports.</p>
                <div class="flex flex-col gap-3">
                    <a href="/login?role=patient" class="text-emerald-600 font-black text-[10px] uppercase tracking-widest hover:translate-x-2 transition-transform">Login to Portal →</a>
                    <a href="/signup?role=patient" class="text-slate-400 font-black text-[10px] uppercase tracking-widest hover:text-emerald-600">Register as Patient</a>
                </div>
            </div>

            <div class="group bg-white p-10 rounded-[2.5rem] shadow-2xl hover:shadow-indigo-100 transition-all border border-slate-50">
                <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-indigo-600 text-3xl">📋</div>
                <h3 class="text-2xl font-bold mb-3">Staff Portal</h3>
                <p class="text-slate-400 text-sm mb-6">Billing and inventory management.</p>
                <div class="flex flex-col gap-3">
                    <a href="/login?role=staff" class="text-indigo-600 font-black text-[10px] uppercase tracking-widest hover:translate-x-2 transition-transform">Login to Portal →</a>
                    <a href="/signup?role=staff" class="text-slate-400 font-black text-[10px] uppercase tracking-widest hover:text-indigo-600">Register as Staff</a>
                </div>
            </div>

        </div>
    </div>

    <section id="find-doctor" class="py-24 px-8 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-extrabold mb-4 uppercase">Our <span class="text-blue-600">Specialists</span></h2>
            <div class="w-20 h-1.5 bg-blue-600 mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <% 
            const doctors = [
                { name: 'Dr. Sanjay Bundiwal', dept: 'Cardiology', exp: '15', img: '1612349317150-e413f6a5b16d' },
                { name: 'Dr. Ananya Sharma', dept: 'Neurology', exp: '12', img: '1559839734-2b71ea197ec2' },
                { name: 'Dr. Rahul Mehta', dept: 'Orthopedics', exp: '10', img: '1622253692010-333f2da6031d' },
                { name: 'Dr. Megha Gupta', dept: 'Pediatrics', exp: '8', img: '1594824476967-48c8b964273f' }
            ];
            doctors.forEach(doc => { %>
                <div class="p-5 border border-slate-100 rounded-3xl hover:shadow-xl transition group bg-white">
                    <img src="https://images.unsplash.com/photo-<%= doc.img %>?auto=format&fit=crop&q=80&w=300" class="w-full h-40 rounded-2xl object-cover mb-4">
                    <h4 class="font-bold text-md"><%= doc.name %></h4>
                    <p class="text-blue-600 font-bold text-[9px] uppercase tracking-widest"><%= doc.dept %> | <%= doc.exp %> Yrs Exp</p>
                    <a href="/signup?role=patient" class="block mt-4 text-center py-2 bg-slate-900 text-white rounded-xl text-[10px] font-bold uppercase tracking-widest">Book Now</a>
                </div>
            <% }); %>
        </div>
    </section>

    <section id="about-us" class="py-24 bg-blue-900 text-white px-12 rounded-[3rem] mx-4">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-4xl font-extrabold mb-6 uppercase tracking-tight">Standard of Excellence</h2>
                <p class="text-blue-200 text-lg mb-8">CareSync HMS offers world-class technology integrated with compassionate care.</p>
                <div class="flex gap-12">
                    <div><h5 class="text-4xl font-black">500+</h5><p class="text-blue-300 text-[10px] uppercase font-bold">Doctors</p></div>
                    <div><h5 class="text-4xl font-black">100k+</h5><p class="text-blue-300 text-[10px] uppercase font-bold">Patients</p></div>
                </div>
            </div>
            <img src="https://images.unsplash.com/photo-1538108197017-c1346673919e?auto=format&fit=crop&q=80" class="rounded-[2rem] shadow-2xl">
        </div>
    </section>

    <section id="contact" class="py-24 px-12 max-w-5xl mx-auto text-center">
        <h2 class="text-4xl font-extrabold mb-12 uppercase tracking-tight">Contact <span class="text-blue-600">Support</span></h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="p-10 bg-slate-50 rounded-[2.5rem]">
                <span class="text-3xl block mb-2">📞</span>
                <p class="font-bold">+91 98765 43210</p>
            </div>
            <div class="p-10 bg-slate-50 rounded-[2.5rem]">
                <span class="text-3xl block mb-2">✉️</span>
                <p class="font-bold">care@caresync.com</p>
            </div>
            <div class="p-10 bg-slate-50 rounded-[2.5rem]">
                <span class="text-3xl block mb-2">📍</span>
                <p class="font-bold">Mumbai, India</p>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

</body>
</html>