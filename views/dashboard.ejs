<div class="space-y-8 animate-in fade-in duration-700">
    
    <div class="relative overflow-hidden bg-blue-600 rounded-[3rem] p-8 md:p-12 shadow-2xl shadow-blue-200">
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 bg-blue-500 rounded-full opacity-50 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-64 h-64 bg-indigo-500 rounded-full opacity-30 blur-3xl"></div>

        <div class="relative flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="space-y-4 text-center md:text-left">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md rounded-full text-white text-xs font-black uppercase tracking-widest border border-white/20">
                    <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                    CareSync Patient Portal
                </div>
                <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter">
                    Stay Healthy, <br><span class="text-blue-100"><%= user.name %></span>
                </h1>
                <p class="text-blue-100 font-medium opacity-80 max-w-md">
                    Welcome to your personalized health hub. Monitor your records and schedule visits instantly.
                </p>
            </div>
            
            <div class="flex flex-col gap-3 w-full md:w-auto">
                <button onclick="window.location.href='/appointments/book'" class="bg-white text-blue-600 px-8 py-4 rounded-[2rem] font-black shadow-xl hover:scale-105 transition-all flex items-center justify-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    BOOK APPOINTMENT
                </button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm flex items-center gap-6">
            <div class="w-16 h-16 bg-blue-50 rounded-3xl flex items-center justify-center text-blue-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Appointment Status</p>
                <h3 class="text-xl font-black text-slate-900">
                    <% 
                        const latest = (typeof recentAppointments !== 'undefined' && recentAppointments.length > 0) ? recentAppointments[0] : null;
                        if(latest && latest.status === 'Pending') { %>
                            <span class="text-orange-500">Awaiting Doctor</span>
                        <% } else if (latest && latest.status === 'Confirmed') { %>
                            <span class="text-blue-600">Scheduled</span>
                        <% } else { %>
                            None Active
                        <% } 
                    %>
                </h3>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm flex items-center gap-6">
            <div class="w-16 h-16 bg-emerald-50 rounded-3xl flex items-center justify-center text-emerald-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Medical Records</p>
                <h3 class="text-xl font-black text-slate-900">Ready</h3>
            </div>
        </div>

        <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-xl flex items-center gap-6">
            <div class="w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center text-blue-400">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
            </div>
            <div class="text-white">
                <p class="text-[10px] font-black text-white/40 uppercase tracking-widest">Payment Info</p>
                <h3 class="text-xl font-black text-green-400">Secured</h3>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-10 py-8 border-b border-slate-50 flex justify-between items-center">
            <h3 class="text-2xl font-black text-slate-900 tracking-tight">Your Medical Visits</h3>
        </div>
        <div class="p-6">
            <% if (typeof recentAppointments !== 'undefined' && recentAppointments.length > 0) { %>
                <div class="space-y-3">
                    <% recentAppointments.forEach(appt => { %>
                        <div class="flex flex-col md:flex-row md:items-center justify-between p-6 rounded-3xl bg-slate-50/50 border border-transparent hover:border-blue-100 transition-all gap-4">
                            <div class="flex items-center gap-4">
                                <div class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center text-blue-600 font-black border border-slate-100">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                </div>
                                <div>
                                    <p class="font-black text-slate-900 text-lg">
                                        Dr. <%= (appt.doctor && appt.doctor.name) ? appt.doctor.name : 'Allocated Doctor' %>
                                    </p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Reason: <%= appt.reason || 'General Checkup' %></p>
                                </div>
                            </div>

                            <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-2">
                                <span class="text-[10px] font-black px-4 py-1.5 rounded-xl uppercase tracking-tighter
                                    <%= appt.status === 'Pending' ? 'bg-orange-100 text-orange-600' : 
                                       appt.status === 'Confirmed' ? 'bg-blue-100 text-blue-600' : 
                                       appt.status === 'Completed' ? 'bg-green-100 text-green-600' : 'bg-slate-100 text-slate-600' %>">
                                    <%= appt.status === 'Pending' ? 'Awaiting Time Slot' : appt.status %>
                                </span>

                                <% if(appt.date && appt.time) { %>
                                    <p class="text-[11px] font-black text-slate-700 bg-white px-3 py-1 rounded-lg shadow-sm border border-slate-100">
                                        <%= new Date(appt.date).toLocaleDateString('en-GB') %> @ <%= appt.time %>
                                    </p>
                                <% } else { %>
                                    <p class="text-[10px] font-bold text-slate-400 italic">TBD by Doctor</p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="py-16 text-center">
                    <div class="inline-flex p-6 bg-slate-50 rounded-full mb-4 text-slate-300">
                        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                    <p class="text-slate-400 font-bold uppercase text-[11px] tracking-widest">No Recent Activity Found</p>
                    <button onclick="window.location.href='/appointments/book'" class="mt-4 text-blue-600 font-black text-xs uppercase hover:underline">Book your first visit</button>
                </div>
            <% } %>
        </div>
    </div>
</div>