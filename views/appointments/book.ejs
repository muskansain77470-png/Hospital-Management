<div class="max-w-3xl mx-auto space-y-8 animate-in fade-in zoom-in duration-500">
    
    <div class="text-center md:text-left space-y-2">
        <h2 class="text-4xl font-black text-blue-950 tracking-tight">Request <span class="text-blue-600">Appointment</span></h2>
        <p class="text-slate-500 font-medium">Select your preferred specialist. Our medical team will review your request and assign a time slot.</p>
    </div>

    <div class="bg-white p-8 md:p-10 rounded-[3rem] shadow-2xl shadow-blue-100/50 border border-slate-100 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-full -mr-16 -mt-16 opacity-50"></div>

        <form action="/appointments" method="POST" class="relative space-y-6">
            
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-2">Choose Specialist</label>
                <div class="relative">
                    <select name="doctorId" required 
                        class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-[1.5rem] outline-none transition-all font-bold text-blue-950 appearance-none">
                        <option value="" disabled selected>Select a Doctor...</option>
                        <% if (typeof doctors !== 'undefined' && doctors.length > 0) { %>
                            <% doctors.forEach(doc => { %>
                                <option value="<%= doc._id %>">Dr. <%= doc.name %> (<%= doc.email %>)</option>
                            <% }) %>
                        <% } else { %>
                            <option value="" disabled>No doctors available at the moment</option>
                        <% } %>
                    </select>
                    <div class="absolute inset-y-0 right-5 flex items-center pointer-events-none">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-2">Reason for Visit</label>
                <textarea name="reason" required placeholder="Describe your symptoms or reason for the consultation (e.g., persistent cough, general checkup)..." 
                    class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-[1.5rem] outline-none transition-all font-bold text-blue-950 h-48 resize-none"></textarea>
            </div>

            <div class="pt-4 flex flex-col md:flex-row gap-4">
                <button type="submit" 
                    class="flex-[2] bg-blue-600 hover:bg-blue-700 text-white py-5 rounded-[1.5rem] font-black uppercase tracking-widest transition-all shadow-xl shadow-blue-200 hover:scale-[1.02] active:scale-95 text-sm">
                    Submit Request
                </button>
                <button type="button" onclick="window.location.href='/dashboard'" 
                    class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-500 py-5 rounded-[1.5rem] font-black uppercase tracking-widest transition-all text-sm">
                    Cancel
                </button>
            </div>
        </form>
    </div>

    <div class="bg-blue-50 p-6 rounded-[2rem] flex items-start gap-4 border border-blue-100">
        <div class="p-2 bg-blue-100 rounded-lg text-blue-600">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
        </div>
        <p class="text-xs font-bold text-blue-800/70 leading-relaxed uppercase tracking-wide">
            Note: After submission, your request will be reviewed. Once a doctor assigns a time slot, the status will change to "Confirmed" in your dashboard.
        </p>
    </div>
</div>